---
import { url } from '../lib/content';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === 'NatesNotes' ? title : `${title} · NatesNotes`}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={new URL(canonical, Astro.site)} />}
  </head>
  <body>
    <div class="container">
      <header class="site-header">
        <a class="site-name" href={url('/')}>NatesNotes</a>
        <nav>
          <a href={url('/')}>Notes</a>
          <a href={url('/courses/')}>Courses</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
