---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { courseNotes, noteTitle, url, type Course } from '../../../lib/content';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({ params: { course: course.id }, props: { course } }));
}

const { course } = Astro.props as { course: Course };
const notes = await courseNotes(course);
---

<Base title={course.data.title} description={course.data.description}>
  <h1>{course.data.title}</h1>
  {course.data.description && <p class="page-desc">{course.data.description}</p>}
  <ol class="entry-list">
    {
      notes.map((note) => (
        <li>
          <div>
            <a class="entry-title" href={url(`/courses/${course.id}/${note.id}/`)}>
              {noteTitle(note)}
            </a>
            {note.data.description && <span class="entry-desc">{note.data.description}</span>}
          </div>
        </li>
      ))
    }
  </ol>
</Base>
